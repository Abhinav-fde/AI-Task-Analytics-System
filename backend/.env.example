# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Connection
# Replace with your MongoDB connection string
# For local: mongodb://localhost:27017/smart-task-analytics
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/smart-task-analytics
MONGODB_URI=mongodb://localhost:27017/smart-task-analytics

# Google Gemini API Key
# Get yours at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# CORS Configuration
# In development, frontend runs on port 4200
# In production, replace with your actual frontend domain
CORS_ORIGIN=http://localhost:4200

# Socket.io Configuration
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000